-- Name: pr_müü_pilet(integer, integer, integer, character varying, integer, boolean); Type: PROCEDURE; Schema: public; Owner: -
--

CREATE PROCEDURE public."pr_müü_pilet"(IN p_lend_id integer, IN p_reisija_id integer, IN p_hind integer, IN "p_tüüp" character varying, IN p_istekoht integer, IN "p_käsipagas" boolean)
    LANGUAGE plpgsql
    AS $$
DECLARE
    v_mahutavus INTEGER;
    v_hõivatud BOOLEAN;
BEGIN
    -- Kontroll 1: lend olemas?
    IF NOT EXISTS (SELECT 1 FROM public."LENNUD" WHERE id = p_lend_id) THEN
        RAISE EXCEPTION 'Lendu ID-ga % ei eksisteeri', p_lend_id;
    END IF;

    -- Kontroll 2: reisija olemas?
    IF NOT EXISTS (SELECT 1 FROM public."REISIJAD" WHERE id = p_reisija_id) THEN
        RAISE EXCEPTION 'Reisijat ID-ga % ei eksisteeri', p_reisija_id;
    END IF;

    -- Kontroll 3: istekoht juba müüdud?
    SELECT EXISTS(
        SELECT 1 FROM public."PILETID" 
        WHERE lend = p_lend_id AND istekoht = p_istekoht
    ) INTO v_hõivatud;
    
    IF v_hõivatud THEN
        RAISE EXCEPTION 'Istekoht % lennul % on juba müüdud', p_istekoht, p_lend_id;
    END IF;

    -- Kontroll 4: istekoha number ei ületa lennuki mahutavust
    SELECT lm.mahutavus INTO v_mahutavus
    FROM public."LENNUD" l
    JOIN public."LENNUKID" lk ON l.lennuk = lk.id
    JOIN public."LENNUKIMUDELID" lm ON lk.mudel = lm.id
    WHERE l.id = p_lend_id;

    IF p_istekoht > v_mahutavus THEN
        RAISE EXCEPTION 'Istekoht % ületab lennuki mahutavuse (%)', 
                        p_istekoht, v_mahutavus;
    END IF;

    -- Kõik korras — sisestame pileti
    INSERT INTO public."PILETID" 
        (lend, omanik, hind, "tüüp", istekoht, "käsipagas", saatja)
    VALUES 
        (p_lend_id, p_reisija_id, p_hind, p_tüüp, p_istekoht, p_käsipagas, NULL);

    RAISE NOTICE 'Pilet edukalt müüdud: lend %, reisija %, istekoht %', 
                 p_lend_id, p_reisija_id, p_istekoht;
END;
$$;


