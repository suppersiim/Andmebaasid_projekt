CREATE FUNCTION public.f_firmastool(p_lennufirma character varying, p_algus timestamp with time zone, p_lopp timestamp with time zone) RETURNS TABLE(id integer, isikukood character varying, eesnimi character varying, perenimi character varying, "sünniaeg" date, rahvus character varying, amet character varying, palk numeric)
    LANGUAGE plpgsql
    AS $$
BEGIN
	return query select distinct m.id, m.isikukood, m.eesnimi, m.perenimi, m.sünniaeg, m.rahvus, m.amet, m.palk
    from "LENNUFIRMAD" firmad
	left join "LENNUKID" lennukid on firmad.id = lennukid.lennufirma
    left join "LENNUD" lennud on lennud.lennuk = lennukid.id
    left join "LENNUD_MEESKONNALIIKMED" lm on lennud.id = lm.lend
    left join "MEESKONNALIIKMED" m on lm.meeskonnaliige = m.id
	where firmad.nimi = p_lennufirma and lennud.algusaeg >= p_algus and lennud.lõppaeg <= p_lopp;
    
END;
$$;


