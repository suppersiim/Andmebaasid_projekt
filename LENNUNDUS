CREATE VIEW public.vw_lendude_ulevaade AS
 SELECT l.id AS lennu_id,
    lj1.nimi AS algus_lennujaam,
    lj2.nimi AS lopp_lennujaam,
    l.algusaeg,
    l."lõppaeg",
    lf.nimi AS lennufirma,
    lm.mudeli_nimi AS lennuki_mudel,
    lm.tootja,
    count(p.id) AS piletite_arv,
    COALESCE(sum(p.hind), (0)::bigint) AS kogutulu_eur
   FROM ((((((public."LENNUD" l
     JOIN public."LENNUJAAMAD" lj1 ON ((l.algus_lennujaam = lj1.id)))
     JOIN public."LENNUJAAMAD" lj2 ON ((l."lõpp_lennujaam" = lj2.id)))
     JOIN public."LENNUKID" lk ON ((l.lennuk = lk.id)))
     JOIN public."LENNUFIRMAD" lf ON ((lk.lennufirma = lf.id)))
     JOIN public."LENNUKIMUDELID" lm ON ((lk.mudel = lm.id)))
     LEFT JOIN public."PILETID" p ON ((p.lend = l.id)))
  GROUP BY l.id, lj1.nimi, lj2.nimi, l.algusaeg, l."lõppaeg", lf.nimi, lm.mudeli_nimi, lm.tootja
  ORDER BY l.algusaeg;


