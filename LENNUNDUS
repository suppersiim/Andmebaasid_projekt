CREATE FUNCTION public.fn_reisija_lennud(p_reisija_id integer) RETURNS TABLE(pileti_id integer, reisija_nimi text, algus_lennujaam character varying, lopp_lennujaam character varying, algusaeg timestamp with time zone, lennufirma character varying, "pileti_tüüp" character varying, istekoht integer, hind integer)
    LANGUAGE plpgsql
    AS $$
BEGIN
    RETURN QUERY
    SELECT 
        p.id,
        (r.eesnimi || ' ' || r.perenimi)::TEXT,
        lj1.nimi,
        lj2.nimi,
        l.algusaeg,
        lf.nimi,
        p."tüüp",
        p.istekoht,
        p.hind
    FROM public."PILETID" p
    JOIN public."REISIJAD" r ON p.omanik = r.id
    JOIN public."LENNUD" l ON p.lend = l.id
    JOIN public."LENNUJAAMAD" lj1 ON l.algus_lennujaam = lj1.id
    JOIN public."LENNUJAAMAD" lj2 ON l."lõpp_lennujaam" = lj2.id
    JOIN public."LENNUKID" lk ON l.lennuk = lk.id
    JOIN public."LENNUFIRMAD" lf ON lk.lennufirma = lf.id
    WHERE p.omanik = p_reisija_id
    ORDER BY l.algusaeg;
END;
$$;


